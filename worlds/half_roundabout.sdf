    <model name="cone_inner_c1"><static>true</static><pose>-0.132 -4.924 0.25 0 0 0</pose><link name="link"><visual name="visual"><geometry><cone><radius>0.15</radius><length>0.5</length></cone></geometry><material><ambient>1 0.3 0 1</ambient><diffuse>1 0.3 0 1</diffuse></material></visual><collision name="collision"><geometry><cone><radius>0.15</radius><length>0.5</length></cone></geometry></collision></link></model>
